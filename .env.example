# ---------------------------------------------------------------------------
# Marketing Task Tracker — environment variables
# Copy to .env and fill in real values:  cp .env.example .env
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
# Local dev via docker-compose (see docker-compose.yml): user/pass/db = trackr.
#   DATABASE_URL and DIRECT_URL are identical locally.
# On Supabase (production):
#   DATABASE_URL = the *pooled* connection (Transaction pooler, port 6543) with
#                  ?pgbouncer=true&connection_limit=1  → used by the app.
#   DIRECT_URL   = the *direct* connection (port 5432)  → used by `prisma migrate`.
# Find both under Supabase → Project Settings → Database → Connection string.
DATABASE_URL="postgresql://trackr:trackr@localhost:5432/trackr?schema=public"
DIRECT_URL="postgresql://trackr:trackr@localhost:5432/trackr?schema=public"

# --- Auth: secret used to sign session cookies (any long random string) ---
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# --- App ---
APP_BASE_URL="http://localhost:3000"

# --- Microsoft Entra ID (M365) SSO ---
# Leave blank to disable the "Sign in with Microsoft" button. To enable, create
# an App Registration in the Azure portal (see README "Microsoft 365 sign-in"),
# then fill these in. Redirect URI to register:
#   <APP_BASE_URL>/api/auth/microsoft/callback
# Sign-in is restricted to PRE-CREATED users (matched by email) — no auto-signup.
MS_TENANT_ID=""
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""

# --- Inbound mailboxes (multi-mailbox) -------------------------------------
# Mailbox CONNECTION CONFIG (host/user/folders/TLS) lives in the database and is
# managed in the app at /marketing-tasks/admin/mailboxes. Only the PASSWORDS
# live here, one env var per mailbox, named IMAP_PASSWORD_<KEY> (key uppercased):
#   IMAP_PASSWORD_CMO="..."     # for the mailbox with key "cmo"
#   IMAP_PASSWORD_OM="..."      # for the mailbox with key "om"
IMAP_PASSWORD_CMO=""
# IMAP_PASSWORD_OM=""

# Legacy single-mailbox vars (optional). If set, they seed the "cmo" mailbox on
# first `db:seed`, and IMAP_PASSWORD acts as a fallback for that one mailbox.
IMAP_HOST="mail.fwsom.com"
IMAP_PORT="993"
IMAP_SECURE="true"
IMAP_USER="tracker-cmo@fwsom.com"
IMAP_PASSWORD=""
# Set "true" only for self-hosted servers with a self-signed / internal-CA cert.
IMAP_ALLOW_SELF_SIGNED="false"

# Folders the worker uses (never deletes mail; moves/marks processed)
EMAIL_PROCESSED_FOLDER="Processed"
EMAIL_FAILED_FOLDER="Failed"
# Set to "true" to move mail into EMAIL_PROCESSED_FOLDER after handling.
# When "false" the worker only flags messages \Seen (safer first run).
EMAIL_MOVE_PROCESSED="false"

# How often the CLI worker polls (cron expression). Default: every 3 minutes.
# Only used by `npm run worker` (continuous mode), not by cron / the endpoint.
WORKER_CRON="*/3 * * * *"

# --- Cron HTTP trigger (for hosted/cPanel deployments) ---------------------
# Secret required to call GET/POST /api/cron/poll. Generate a long random value.
# Then schedule (e.g. cPanel Cron Jobs, every 3 min):
#   curl -fsS -H "Authorization: Bearer YOUR_SECRET" https://your-subdomain/api/cron/poll
CRON_SECRET=""

# --- Attachment storage (V1 stores metadata; file bytes optional) ---
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
